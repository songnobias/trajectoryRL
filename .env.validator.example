# TrajectoryRL Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# =============================================================================
# LLM API Configuration (OpenAI-compatible)
# =============================================================================

# API key for the LLM provider (required)
# For Chutes: get your key at https://chutes.ai
CLAWBENCH_LLM_API_KEY=

# Base URL for the OpenAI-compatible API (required)
# Examples:
#   https://llm.chutes.ai/v1               (Chutes, default)
#   https://open.bigmodel.cn/api/paas/v4   (Zhipu direct, alternative)
CLAWBENCH_LLM_BASE_URL=https://llm.chutes.ai/v1

# =============================================================================
# Model Selection
# =============================================================================
# LLM model for evaluation (provider/model format)
# The prefix must match a provider defined in config/openclaw.json.template.
# Examples:
#   chutes/zai-org/GLM-5-TEE               (Chutes GLM-5, default)
#   zhipu/glm-5                            (Zhipu direct, alternative)
CLAWBENCH_DEFAULT_MODEL=chutes/zai-org/GLM-5-TEE

# =============================================================================
# Bittensor
# =============================================================================
WALLET_NAME=validator
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney          # finney, test, or local

# =============================================================================
# Optional
# =============================================================================
# EVAL_INTERVAL_BLOCKS=1200  # Blocks between evaluation rounds (default: 1200 ≈ 4h)
# WEIGHT_INTERVAL_BLOCKS=360 # Blocks between weight updates (default: 360 ≈ 72min)
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
